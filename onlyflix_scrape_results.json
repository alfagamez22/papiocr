  "player_workflow": {
    "step_1": "User clicks Play button on onlyflix.to",
    "step_2": "AJAX POST to wp-admin/admin-ajax.php with: action (likely of_ajax), nonce, post_id, content_type",
    "step_3": "Player iframe loads one of the 4 public server URLs (e.g., vidapi.xyz)",
    "step_4": "VidAPI.xyz shows poster backdrop + play overlay button",
    "step_5": "User clicks play overlay → iframe.src is set to data-src (actual stream URL)",
    "step_6": "Server panel appears showing 11 sub-servers to choose from",
    "step_7": "Clicking another sub-server swaps data-src and reloads iframe"
  },
